# examples/grc-prod.env -- prod profile config for erambox (Cognis Digital)
#
# Hardened deployment: TLS-terminating proxy, no host-published app/db ports,
# strong secrets, real public hostname. Generate with:
#   erambox.sh generate --config grc-prod.env --profile prod --out ./out-prod

ERAMBOX_PROFILE=prod

# --- application ---------------------------------------------------------
APP_NAME=grcprod
APP_IMAGE=grc/webapp:1.4.2
APP_PORT=8080            # internal-only in prod; not published on the host
APP_INTERNAL_PORT=8080
APP_SECRET_KEY=replace-with-a-long-random-secret-value-please
HEALTH_PATH=/health

# --- database ------------------------------------------------------------
DB_IMAGE=postgres:16-alpine
DB_NAME=grc
DB_USER=grc
DB_PASSWORD=Str0ng-Prod-DB-Passw0rd-Change-Me
# Note: no DB_PORT -> the database is not published on the host.

# --- reverse proxy -------------------------------------------------------
PROXY_IMAGE=nginx:1.27-alpine
PROXY_HTTP_PORT=80       # redirects to HTTPS
PROXY_HTTPS_PORT=443

# --- networking ----------------------------------------------------------
PUBLIC_HOSTNAME=grc.example.com

# --- TLS (prod: required) ------------------------------------------------
TLS_ENABLED=true
TLS_CERT_PATH=/etc/letsencrypt/live/grc.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/grc.example.com/privkey.pem
