# examples/grc.env -- dev profile config for erambox (Cognis Digital)
#
# A generic self-hosted GRC stack: web app + database + reverse proxy.
# Copy this file, edit values, then:
#   erambox.sh generate --config grc.env --profile dev --out ./out

ERAMBOX_PROFILE=dev

# --- application ---------------------------------------------------------
APP_NAME=grcdev
APP_IMAGE=grc/webapp:latest
APP_PORT=8080            # host port the app is published on (dev only)
APP_INTERNAL_PORT=8080   # port the app listens on inside the container
APP_SECRET_KEY=dev-insecure-secret
HEALTH_PATH=/health

# --- database ------------------------------------------------------------
DB_IMAGE=postgres:16-alpine
DB_NAME=grc
DB_USER=grc
DB_PASSWORD=grc-dev-password
DB_PORT=5432             # publish Postgres on the host for local inspection

# --- reverse proxy -------------------------------------------------------
PROXY_IMAGE=nginx:1.27-alpine
PROXY_HTTP_PORT=8000     # host HTTP port for the proxy

# --- networking ----------------------------------------------------------
PUBLIC_HOSTNAME=localhost

# --- TLS (dev: disabled) -------------------------------------------------
TLS_ENABLED=false
